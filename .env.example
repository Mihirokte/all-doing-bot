# Copy to .env and fill in values. Do not commit .env.

# ----- LLM (real output) -----
# API key for remote OpenAI-compatible provider. If unset, backend may use mock/local only.
REMOTE_LLM_API_KEY=
REMOTE_LLM_BASE_URL=https://api.groq.com/openai/v1
REMOTE_LLM_MODEL=llama-3.1-8b-instant
# Order of providers to try: local, remote, mock
LLM_PROVIDER_PRIORITY=local,remote,mock
# Optional: path to local GGUF model for "local" provider
MODEL_PATH=

# ----- Google Sheets persistence -----
# Path to Google service account JSON. If unset, backend uses in-memory fake persistence.
GOOGLE_CREDS_PATH=
# Google Sheet ID for catalogue and cohort data
SPREADSHEET_ID=

# ----- Server -----
HOST=0.0.0.0
PORT=8000
# Comma-separated origins allowed for CORS (e.g. http://localhost:3000,https://your-app.pages.dev)
CORS_ALLOW_ORIGINS=
