# Copy to .env and fill in values. Do not commit .env.

# ----- LLM (real output) -----
# Ollama (local server): base URL and model (e.g. qwen3.5:4b). First choice when set.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
# Order of providers (default no API keys): ollama, local (GGUF), mock
LLM_PROVIDER_PRIORITY=ollama,local,mock
# Optional: path to local GGUF model for "local" provider
MODEL_PATH=
# Remote API (optional opt-in; not needed for default Qwen local runtime)
REMOTE_LLM_API_KEY=
REMOTE_LLM_BASE_URL=https://api.groq.com/openai/v1
REMOTE_LLM_MODEL=llama-3.1-8b-instant
# Web search in chat: set to true to use SearXNG for search-like short queries (requires SearXNG). Default false = LLM-only answers.
# CHAT_WEB_SEARCH_ENABLED=false
# ----- Web search (LangGraph + MCP are required; default search provider is MCP) -----
# Backend needs Python 3.10+ and: pip install -r apps/backend/requirements.txt (includes langgraph, mcp).
# JSON array of argv to start your MCP search server (stdio), e.g. npx or a local binary:
MCP_SEARCH_COMMAND_JSON='["npx","-y","your-mcp-search-package"]'
MCP_SEARCH_TOOL_NAME=search
MCP_SEARCH_QUERY_PARAM=query
# Default search backend: mcp (required in production). Use searxng only if you intentionally use SearXNG instead.
CONNECTOR_SEARCH_DEFAULT_PROVIDER=mcp
# SearXNG (optional fallback). Used when CONNECTOR_SEARCH_DEFAULT_PROVIDER=searxng or as non-default connector.
SEARXNG_BASE_URL=http://localhost:8888
# Optional: Cloudflare Browser Rendering (crawl). When set, enriches search_web with full Markdown for top 2 result URLs and uses it for web_fetch (bot-friendly, partial success per URL).
# Create token with "Browser Rendering - Edit": https://developers.cloudflare.com/browser-rendering/rest-api/crawl-endpoint/
# Quality: more reliable content when sites block bots; render=false keeps crawls fast and Workers-based during beta.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ----- Google Sheets persistence (Drive + Sheets APIs) -----
# Path to Google service account JSON (e.g. poke-tasks-433-0f24574c2341.json). If unset, in-memory fake.
GOOGLE_CREDS_PATH=poke-tasks-433-0f24574c2341.json
# Optional: use a specific spreadsheet by ID. If unset, spreadsheet is found or created by name below.
SPREADSHEET_ID=
# Name of the spreadsheet to use: open by title if it exists, else create. Ignored when SPREADSHEET_ID is set.
GOOGLE_SHEETS_SPREADSHEET_NAME=all-doing-bot cohorts

# ----- Queue / orchestration -----
# Set REDIS_URL to enable external worker execution + durable checkpoints.
REDIS_URL=redis://localhost:6379/0
# Emergency rollback only: if true, fallback to legacy in-process execution when queue path fails.
ORCHESTRATOR_LEGACY_FALLBACK_ENABLED=false

# ----- Server -----
HOST=0.0.0.0
PORT=8000
# Comma-separated origins allowed for CORS (e.g. http://localhost:3000,https://your-app.pages.dev)
CORS_ALLOW_ORIGINS=
