# Copy to .env and fill in values. Do not commit .env.

# ----- LLM (real output) -----
# Ollama (local server): base URL and model (e.g. qwen3.5:4b). First choice when set.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
# Order of providers: ollama, local (GGUF), remote (API), mock
LLM_PROVIDER_PRIORITY=ollama,local,remote,mock
# Optional: path to local GGUF model for "local" provider
MODEL_PATH=
# Remote API (fallback when Ollama/local unavailable)
REMOTE_LLM_API_KEY=
REMOTE_LLM_BASE_URL=https://api.groq.com/openai/v1
REMOTE_LLM_MODEL=llama-3.1-8b-instant
# Web search (SearXNG). Backend uses this for search_web action.
SEARXNG_BASE_URL=http://localhost:8888

# ----- Google Sheets persistence (Drive + Sheets APIs) -----
# Path to Google service account JSON (e.g. poke-tasks-433-0f24574c2341.json). If unset, in-memory fake.
GOOGLE_CREDS_PATH=poke-tasks-433-0f24574c2341.json
# Optional: use a specific spreadsheet by ID. If unset, spreadsheet is found or created by name below.
SPREADSHEET_ID=
# Name of the spreadsheet to use: open by title if it exists, else create. Ignored when SPREADSHEET_ID is set.
GOOGLE_SHEETS_SPREADSHEET_NAME=all-doing-bot cohorts

# ----- Server -----
HOST=0.0.0.0
PORT=8000
# Comma-separated origins allowed for CORS (e.g. http://localhost:3000,https://your-app.pages.dev)
CORS_ALLOW_ORIGINS=
